{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 30, "patch": 0 },
    "configurePresets": [
        {
            "name": "_base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "debug",
            "inherits": "_base",
            "displayName": "Debug",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "release",
            "inherits": "_base",
            "displayName": "Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXE_LINKER_FLAGS_RELEASE": "-s",
                "CMAKE_SHARED_LINKER_FLAGS_RELEASE": "-s"
            }
        },
        {
            "name": "coverage",
            "inherits": "_base",
            "displayName": "Coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_COVERAGE": "ON"
            }
        },
        {
            "name": "asan",
            "inherits": "_base",
            "displayName": "ASan + UBSan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_ASAN": "ON"
            }
        },
        {
            "name": "tsan",
            "inherits": "_base",
            "displayName": "TSan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_TSAN": "ON"
            }
        },
        {
            "name": "static",
            "inherits": "release",
            "displayName": "Static (musl)",
            "cacheVariables": { "SCAFFOLD_STATIC_BINARIES": "ON" }
        },
        {
            "name": "clang-debug",
            "inherits": "debug",
            "displayName": "Clang Debug (portability canary)",
            "cacheVariables": { "CMAKE_CXX_COMPILER": "clang++" }
        }
    ],
    "buildPresets": [
        { "name": "debug",       "configurePreset": "debug",       "jobs": 0 },
        { "name": "release",     "configurePreset": "release",     "jobs": 0 },
        { "name": "coverage",    "configurePreset": "coverage",    "jobs": 0 },
        { "name": "asan",        "configurePreset": "asan",        "jobs": 0 },
        { "name": "tsan",        "configurePreset": "tsan",        "jobs": 0 },
        { "name": "static",      "configurePreset": "static",      "jobs": 0 },
        { "name": "clang-debug", "configurePreset": "clang-debug", "jobs": 0 }
    ],
    "testPresets": [
        { "name": "debug",       "configurePreset": "debug",       "output": { "outputOnFailure": true } },
        { "name": "release",     "configurePreset": "release",     "output": { "outputOnFailure": true } },
        { "name": "coverage",    "configurePreset": "coverage",    "output": { "outputOnFailure": true } },
        { "name": "asan",        "configurePreset": "asan",        "output": { "outputOnFailure": true } },
        { "name": "tsan",        "configurePreset": "tsan",        "output": { "outputOnFailure": true } },
        { "name": "static",      "configurePreset": "static",      "output": { "outputOnFailure": true } },
        { "name": "clang-debug", "configurePreset": "clang-debug", "output": { "outputOnFailure": true } }
    ]
}
